# Copiá este archivo como secrets.toml para desarrollo local
# o cargá las mismas claves en Streamlit Cloud → Settings → Secrets.

# Producción (Streamlit Cloud): pegá la URL de Neon → Connection string → Copy snippet
# Debe incluir usuario, contraseña, host y ?sslmode=require
DATABASE_URL = "postgresql://neondb_owner:CONTRASEÑA@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require"
