# Copiá este archivo como secrets.toml para desarrollo local
# o cargá las mismas claves en Streamlit Cloud → Settings → Secrets.

# PostgreSQL (Neon, Supabase, Railway, etc.)
# Sin esta variable, EvaluAR usa SQLite local (datos efímeros en Cloud).
DATABASE_URL = "postgresql://usuario:contraseña@host:5432/evaluar"
